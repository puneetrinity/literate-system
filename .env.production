# ====================================
# Production Environment Configuration
# ====================================

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=warning

# Service Ports (production)
AI_CHAT_SERVICE_PORT=8003
DOCUMENT_SEARCH_SERVICE_PORT=8001
UNIFIED_UI_PORT=8000

# Production service URLs
DOCUMENT_SEARCH_URL=http://document-search:8001
AI_CHAT_URL=http://ai-chat:8003
PUBLIC_AI_CHAT_URL=https://api.your-domain.com/api/v1
PUBLIC_DOC_SEARCH_URL=https://api.your-domain.com/api/v2

# Production Database and Cache
REDIS_URL=${PRODUCTION_REDIS_URL}
REDIS_PASSWORD=${PRODUCTION_REDIS_PASSWORD}
REDIS_MAX_CONNECTIONS=50
CLICKHOUSE_HOST=${PRODUCTION_CLICKHOUSE_HOST}
CLICKHOUSE_PASSWORD=${PRODUCTION_CLICKHOUSE_PASSWORD}
OLLAMA_HOST=http://ollama:11434

# Production Models
DEFAULT_MODEL=phi3:mini
FALLBACK_MODEL=phi3:mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Production API Keys (from secrets/environment)
BRAVE_API_KEY=${PRODUCTION_BRAVE_API_KEY}
SCRAPINGBEE_API_KEY=${PRODUCTION_SCRAPINGBEE_API_KEY}
OPENAI_API_KEY=${PRODUCTION_OPENAI_API_KEY}
ANTHROPIC_API_KEY=${PRODUCTION_ANTHROPIC_API_KEY}

# Security (production secrets)
SECRET_KEY=${PRODUCTION_SECRET_KEY}
ALLOWED_ORIGINS=["https://your-domain.com", "https://api.your-domain.com"]
ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE"]
FORCE_HTTPS=true

# Production Performance Settings
DEFAULT_MONTHLY_BUDGET=20.0
COST_ALERT_THRESHOLD=0.9
MAX_COST_PER_REQUEST=0.5
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=2000
RATE_LIMIT_PER_DAY=20000
REQUEST_TIMEOUT=15
TARGET_RESPONSE_TIME=1.5
MAX_EXECUTION_TIME=30
MAX_CONCURRENT_REQUESTS=200

# Production Server Configuration
WORKERS=4
MAX_WORKERS=8
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_TIMEOUT=30
KEEPALIVE=2
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100

# SSL Configuration
SSL_CERT_PATH=${SSL_CERT_PATH}
SSL_KEY_PATH=${SSL_KEY_PATH}

# Production Features (selective enabling)
ENABLE_MULTI_AGENT=true
ENABLE_MEMORY_SYSTEM=true
ENABLE_ADAPTIVE_ROUTING=true
ENABLE_COST_OPTIMIZATION=true
ENABLE_VECTOR_SEARCH=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_HYBRID_SEARCH=true
ENABLE_AUTO_INDEXING=true
ENABLE_ANALYTICS=true
ENABLE_A_B_TESTING=false  # Disabled in production initially
ENABLE_PERFORMANCE_MONITORING=true

# Production Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=15
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3

# Production Logging
LOG_FORMAT=json
LOG_FILE=./logs/production.log
LOG_ROTATION=midnight
LOG_RETENTION_DAYS=90

# File Processing (production limits)
MAX_FILE_SIZE=25  # MB
ALLOWED_FILE_TYPES=["txt", "pdf", "docx", "json", "md"]
UPLOAD_DIRECTORY=./data/production_uploads
CHUNK_SIZE=800
CHUNK_OVERLAP=150
VECTOR_DIMENSION=384
SIMILARITY_THRESHOLD=0.75
MAX_RESULTS=15

# Production Caching
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=5000
ENABLE_RESPONSE_CACHING=true

# Cloud Provider Settings
AWS_REGION=${AWS_REGION}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_S3_BUCKET=${AWS_S3_BUCKET}

# Docker Registry
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=${DOCKER_USERNAME}
DOCKER_PASSWORD=${DOCKER_PASSWORD}

# Production Optimizations
OMP_NUM_THREADS=4
OPENBLAS_NUM_THREADS=4
MKL_NUM_THREADS=4
TOKENIZERS_PARALLELISM=false
NUMBA_CACHE_DIR=/tmp/numba_cache

# Disable development features
RELOAD=false
ENABLE_DEBUG_MODE=false
PYTEST_WORKERS=1