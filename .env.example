# =================================
# Unified AI Search System Configuration
# =================================

# Environment Settings
ENVIRONMENT=production
DEBUG=false

# Services Configuration
REDIS_URL=redis://localhost:6379
OLLAMA_HOST=http://localhost:11434
DOCUMENT_SEARCH_URL=http://localhost:8001

# API Keys (Required for full functionality)
BRAVE_API_KEY=your_brave_search_api_key_here
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# Model Configuration
DEFAULT_MODEL=phi3:mini
FALLBACK_MODEL=llama3.2
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Performance & Cost Settings
DEFAULT_MONTHLY_BUDGET=50.0
RATE_LIMIT_PER_MINUTE=120
TARGET_RESPONSE_TIME=2.0

# Ultra Fast Search Optimization Settings
HNSW_EF_SEARCH=150
HNSW_MAX_CONNECTIONS=16
LSH_NUM_HASHES=16
BM25_K1=1.2
QUERY_CACHE_SIZE=5000

# Deep Dive Research Settings
ENABLE_WEB_SEARCH_IN_RESEARCH=true
MAX_RESEARCH_COST_PER_QUERY=1.0
RESEARCH_TIMEOUT_SECONDS=45

# Database Settings
INDEX_PATH=./indexes
DATA_PATH=./data

# Security Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_KEY_HEADER=X-API-Key

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json

# Health Check Settings
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60