# ====================================
# Development Environment Configuration
# ====================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# Service Ports (development)
AI_CHAT_SERVICE_PORT=8003
DOCUMENT_SEARCH_SERVICE_PORT=8001
UNIFIED_UI_PORT=8000

# Local service URLs
DOCUMENT_SEARCH_URL=http://localhost:8001
AI_CHAT_URL=http://localhost:8003
REDIS_URL=redis://localhost:6379
OLLAMA_HOST=http://localhost:11434

# Default development settings
DEFAULT_MODEL=phi3:mini
FALLBACK_MODEL=phi3:mini

# Development API keys (use test/mock keys)
BRAVE_API_KEY=dev_brave_key_replace_with_real
SCRAPINGBEE_API_KEY=dev_scrapingbee_key_replace_with_real

# Security (weak settings for development)
SECRET_KEY=dev-secret-key-not-for-production
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://127.0.0.1:3000", "http://127.0.0.1:8000"]

# Performance (relaxed for development)
DEFAULT_MONTHLY_BUDGET=100.0
RATE_LIMIT_PER_MINUTE=300
REQUEST_TIMEOUT=60
MAX_EXECUTION_TIME=120

# Development features
RELOAD=true
ENABLE_DEBUG_MODE=true
ENABLE_METRICS=true

# Testing
TEST_DATABASE_URL=sqlite:///./test_dev.db

# File uploads (development)
MAX_FILE_SIZE=100
UPLOAD_DIRECTORY=./data/dev_uploads