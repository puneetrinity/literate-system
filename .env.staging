# ====================================
# Staging Environment Configuration
# ====================================

# Environment
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=info

# Service Ports (staging)
AI_CHAT_SERVICE_PORT=8003
DOCUMENT_SEARCH_SERVICE_PORT=8001
UNIFIED_UI_PORT=8000

# Staging service URLs (use actual staging endpoints)
DOCUMENT_SEARCH_URL=http://document-search:8001
AI_CHAT_URL=http://ai-chat:8003
PUBLIC_AI_CHAT_URL=https://staging-api.your-domain.com/api/v1
PUBLIC_DOC_SEARCH_URL=https://staging-api.your-domain.com/api/v2

# Database and Cache (staging instances)
REDIS_URL=redis://staging-redis:6379
CLICKHOUSE_HOST=staging-clickhouse
OLLAMA_HOST=http://staging-ollama:11434

# Production-like models
DEFAULT_MODEL=phi3:mini
FALLBACK_MODEL=phi3:mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# API Keys (staging/test keys)
BRAVE_API_KEY=${STAGING_BRAVE_API_KEY}
SCRAPINGBEE_API_KEY=${STAGING_SCRAPINGBEE_API_KEY}
OPENAI_API_KEY=${STAGING_OPENAI_API_KEY}

# Security (production-like but not production secrets)
SECRET_KEY=${STAGING_SECRET_KEY}
ALLOWED_ORIGINS=["https://staging.your-domain.com", "https://staging-api.your-domain.com"]

# Performance (production-like settings)
DEFAULT_MONTHLY_BUDGET=25.0
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=5000
REQUEST_TIMEOUT=30
TARGET_RESPONSE_TIME=2.5
MAX_EXECUTION_TIME=60

# Server Configuration
WORKERS=2
MAX_WORKERS=4
WORKER_TIMEOUT=60
KEEPALIVE=2

# Features (enable all for testing)
ENABLE_MULTI_AGENT=true
ENABLE_MEMORY_SYSTEM=true
ENABLE_ADAPTIVE_ROUTING=true
ENABLE_COST_OPTIMIZATION=true
ENABLE_ANALYTICS=true
ENABLE_A_B_TESTING=true

# Monitoring
ENABLE_METRICS=true
HEALTH_CHECK_INTERVAL=30
LOG_FORMAT=json
LOG_RETENTION_DAYS=7

# File processing
MAX_FILE_SIZE=50
UPLOAD_DIRECTORY=./data/staging_uploads
CHUNK_SIZE=1000
VECTOR_DIMENSION=384

# Caching
CACHE_TTL=1800  # 30 minutes
ENABLE_RESPONSE_CACHING=true