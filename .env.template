# ====================================
# Unified AI System - Environment Configuration Template
# ====================================
# Copy this file to .env and fill in your actual values
# Different environments (dev/staging/prod) should have their own .env files

# ====================================
# Environment Configuration
# ====================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=info  # debug, info, warning, error, critical

# ====================================
# Service Ports and URLs
# ====================================
AI_CHAT_SERVICE_PORT=8003
DOCUMENT_SEARCH_SERVICE_PORT=8001
UNIFIED_UI_PORT=8000

# Internal service URLs (for docker-compose)
DOCUMENT_SEARCH_URL=http://document-search:8001
AI_CHAT_URL=http://ai-chat:8003

# External URLs (for production deployment)
PUBLIC_AI_CHAT_URL=https://your-domain.com/api/v1
PUBLIC_DOC_SEARCH_URL=https://your-domain.com/api/v2

# ====================================
# Database and Cache Configuration
# ====================================
# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_TIMEOUT=5

# ClickHouse Configuration (for analytics)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=unified_ai_analytics

# ====================================
# AI Model Configuration
# ====================================
# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# Default Models
DEFAULT_MODEL=phi3:mini
FALLBACK_MODEL=phi3:mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Model Performance Settings
MAX_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9

# ====================================
# External API Keys
# ====================================
# Search Provider APIs
BRAVE_API_KEY=your_brave_search_api_key_here
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# OpenAI API (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# Anthropic API (if using Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ====================================
# Security Configuration
# ====================================
# JWT Settings
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://your-domain.com"]
ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
ALLOWED_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# ====================================
# Performance and Cost Management
# ====================================
# Budget Management
DEFAULT_MONTHLY_BUDGET=50.0
COST_ALERT_THRESHOLD=0.8
MAX_COST_PER_REQUEST=1.0

# Performance Settings
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
TARGET_RESPONSE_TIME=2.0
MAX_EXECUTION_TIME=60

# Caching Settings
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=1000
ENABLE_RESPONSE_CACHING=true

# ====================================
# Document Processing Configuration
# ====================================
# File Upload Settings
MAX_FILE_SIZE=50  # MB
ALLOWED_FILE_TYPES=["txt", "pdf", "docx", "xlsx", "json", "md"]
UPLOAD_DIRECTORY=./data/uploads

# Vector Index Settings
VECTOR_DIMENSION=384
INDEX_TYPE=hnsw  # hnsw, ivf_pq, lsh
SIMILARITY_THRESHOLD=0.7
MAX_RESULTS=20

# Text Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MIN_CHUNK_SIZE=100

# ====================================
# Monitoring and Observability
# ====================================
# Metrics Collection
ENABLE_METRICS=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Logging Configuration
LOG_FORMAT=json  # json, text
LOG_FILE=./logs/app.log
LOG_ROTATION=midnight
LOG_RETENTION_DAYS=30

# ====================================
# Development Settings
# ====================================
# Hot Reload (development only)
RELOAD=true
RELOAD_DIRS=["app"]

# Testing
TEST_DATABASE_URL=sqlite:///./test.db
PYTEST_WORKERS=4

# Debugging
ENABLE_DEBUG_MODE=false
DEBUG_PORT=5678

# ====================================
# Production Settings
# ====================================
# Server Configuration
WORKERS=4
MAX_WORKERS=8
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_TIMEOUT=120
KEEPALIVE=2

# SSL Configuration (production)
SSL_CERT_PATH=
SSL_KEY_PATH=
FORCE_HTTPS=false

# ====================================
# Feature Flags
# ====================================
# AI Features
ENABLE_MULTI_AGENT=true
ENABLE_MEMORY_SYSTEM=true
ENABLE_ADAPTIVE_ROUTING=true
ENABLE_COST_OPTIMIZATION=true

# Search Features
ENABLE_VECTOR_SEARCH=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_HYBRID_SEARCH=true
ENABLE_AUTO_INDEXING=true

# Analytics Features
ENABLE_ANALYTICS=true
ENABLE_A_B_TESTING=true
ENABLE_PERFORMANCE_MONITORING=true

# ====================================
# Cloud Provider Settings (if applicable)
# ====================================
# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# RunPod Configuration
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Docker Registry
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=
DOCKER_PASSWORD=