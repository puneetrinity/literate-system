# Chainlit Frontend Environment Variables

# AI Chat Service Configuration (REQUIRED)
AI_CHAT_SERVICE_URL=https://your-ai-chat-service.railway.app

# Application Configuration
PORT=8080
DEFAULT_CHAT_MODE=unified

# API Settings
API_TIMEOUT=60

# Chainlit Configuration
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8080

# Optional: Authentication
# CHAINLIT_AUTH_SECRET=your-secret-key
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Database for conversation persistence
# CHAINLIT_DATABASE_URL=postgresql://user:pass@host:5432/chainlit

# Optional: Literal AI integration (for monitoring)
# LITERAL_API_KEY=your-literal-api-key
