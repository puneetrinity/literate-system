# Multi-stage Dockerfile for AI Chat Service with advanced optimizations
# Optimized for production deployment with minimal attack surface

# ================================
# Base Python Image with Security Patches
# ================================
FROM python:3.10-slim-bullseye AS base

# Install security updates and system dependencies
RUN apt-get update && apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        build-essential \
        gcc \
        g++ \
        curl \
        git \
        pkg-config \
        && \
    rm -rf /var/lib/apt/lists/* && \
    apt-get clean

# Create non-root user early for security
RUN groupadd -r appgroup && \
    useradd -r -g appgroup -d /app -s /bin/bash appuser

# Set environment variables for Python optimization
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_DEFAULT_TIMEOUT=100

# ================================
# Dependencies Stage - Cacheable Layer
# ================================
FROM base AS dependencies

WORKDIR /app

# Upgrade pip and install build tools
RUN pip install --upgrade pip setuptools wheel

# Copy requirements first for better caching
COPY requirements.txt requirements-dev.txt ./

# Install Python dependencies with optimization flags
RUN pip install --no-cache-dir \
    --compile \
    --global-option=build_ext \
    --global-option=-j4 \
    -r requirements.txt && \
    pip install --no-cache-dir \
    --compile \
    -r requirements-dev.txt

# Clean up build dependencies to reduce image size
RUN apt-get autoremove -y build-essential gcc g++ && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ================================
# Application Code Stage
# ================================
FROM dependencies AS application

WORKDIR /app

# Copy application code with proper ownership
COPY --chown=appuser:appgroup app/ ./app/
COPY --chown=appuser:appgroup scripts/ ./scripts/
COPY --chown=appuser:appgroup tests/ ./tests/
COPY --chown=appuser:appgroup pytest.ini ./
COPY --chown=appuser:appgroup .env* ./

# Create necessary directories with proper permissions
RUN mkdir -p /app/data /app/logs /app/cache && \
    chown -R appuser:appgroup /app && \
    chmod -R 755 /app

# ================================
# Production Stage - Minimal Runtime
# ================================
FROM python:3.10-slim-bullseye AS production

# Install only runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && \
    rm -rf /var/lib/apt/lists/* && \
    apt-get clean

# Create non-root user
RUN groupadd -r appgroup && \
    useradd -r -g appgroup -d /app -s /bin/bash appuser

# Set optimized environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PORT=8003 \
    WORKERS=1 \
    MAX_WORKERS=4 \
    TIMEOUT=120 \
    KEEPALIVE=2 \
    MAX_REQUESTS=1000 \
    MAX_REQUESTS_JITTER=100

WORKDIR /app

# Copy Python packages from dependencies stage
COPY --from=dependencies /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=dependencies /usr/local/bin /usr/local/bin

# Copy application code from application stage
COPY --from=application --chown=appuser:appgroup /app ./

# Create data directories with proper permissions
RUN mkdir -p /app/data /app/logs /app/cache /tmp/app && \
    chown -R appuser:appgroup /app /tmp/app && \
    chmod -R 755 /app

# Switch to non-root user
USER appuser

# Expose application port
EXPOSE 8003

# Add comprehensive health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl --fail --silent --max-time 10 http://localhost:8003/health/live || exit 1

# Add metadata labels for better container management
LABEL \
    org.opencontainers.image.title="AI Chat Service" \
    org.opencontainers.image.description="Unified AI Chat Service with LangGraph and Multi-Agent Support" \
    org.opencontainers.image.version="1.0.0" \
    org.opencontainers.image.vendor="Unified AI System" \
    org.opencontainers.image.licenses="MIT" \
    maintainer="AI Team <ai-team@company.com>"

# Production-optimized startup command
CMD ["sh", "-c", "exec uvicorn app.main:app --host 0.0.0.0 --port ${PORT} --workers ${WORKERS} --timeout-keep-alive ${KEEPALIVE} --access-log --log-level info --loop uvloop"]

# ================================
# Development Stage (Optional)
# ================================
FROM application AS development

# Install additional development tools
RUN pip install --no-cache-dir \
    debugpy \
    pytest-watch \
    jupyter

# Development environment variables
ENV DEBUG=true \
    RELOAD=true \
    LOG_LEVEL=debug

# Expose debug port
EXPOSE 5678

# Development startup with hot reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8003", "--reload", "--log-level", "debug"]

# ================================
# Testing Stage
# ================================
FROM application AS testing

# Set testing environment
ENV ENVIRONMENT=test \
    CI=true

# Run tests and generate coverage report
RUN python -m pytest tests/ \
    --cov=app \
    --cov-report=xml \
    --cov-report=html \
    --cov-report=term \
    --tb=short \
    -v

# Copy test results for extraction
COPY --chown=appuser:appgroup coverage.xml htmlcov/ ./test-results/