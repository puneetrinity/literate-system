# Railway Environment Variables Template
# Copy this to Railway's environment variables section

# Application Configuration
ENVIRONMENT=production
DEBUG=false
PORT=8000

# LLM Provider Configuration
LLM_PROVIDER=runpod

# RunPod API Configuration (REQUIRED)
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_endpoint_id_here

# Redis Configuration (Use Railway Redis addon)
REDIS_URL=${REDIS_URL}

# Document Search Service URL
DOCUMENT_SEARCH_URL=${DOCUMENT_SEARCH_URL}

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend.railway.app,https://your-lobechat.railway.app

# Optional: API Keys for search providers
BRAVE_API_KEY=${BRAVE_API_KEY}
SCRAPINGBEE_API_KEY=${SCRAPINGBEE_API_KEY}

# Optional: External LLM fallbacks
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Security
JWT_SECRET_KEY=${JWT_SECRET_KEY}

# Performance Settings
RATE_LIMIT_PER_MINUTE=100
TARGET_RESPONSE_TIME=2.5
CACHE_TTL_DEFAULT=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
