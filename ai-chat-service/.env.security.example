# Security Configuration Example
# Copy this file to .env and customize for your environment

# =============================================================================
# ENCRYPTION CONFIGURATION
# =============================================================================

# Master key for data encryption (hex-encoded, 64 characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=your_64_character_hex_encoded_master_key_here

# Master key for configuration encryption (base64-encoded)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_MASTER_KEY=your_base64_encoded_config_master_key_here

# Secret key for audit log HMAC signatures
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUDIT_SECRET_KEY=your_audit_secret_key_here

# Data protection settings
ENABLE_DATA_ENCRYPTION=true
ENABLE_AUDIT_LOGGING=true
ENABLE_GDPR_COMPLIANCE=true
ENABLE_KEY_ROTATION=true

# =============================================================================
# TLS/SSL CONFIGURATION
# =============================================================================

# Enable TLS for the main application
TLS_ENABLED=false

# SSL certificate paths
SERVER_SSL_CERT=/etc/ssl/certs/server.crt
SERVER_SSL_KEY=/etc/ssl/private/server.key
SERVER_CA_CERT=/etc/ssl/certs/ca.crt
SSL_CERT_DIR=/etc/ssl/certs

# =============================================================================
# REDIS TLS CONFIGURATION
# =============================================================================

# Enable TLS for Redis connections
REDIS_TLS_ENABLED=false

# Redis TLS certificate paths
REDIS_CA_CERT=/etc/ssl/certs/redis-ca.crt
REDIS_CLIENT_CERT=/etc/ssl/certs/redis-client.crt
REDIS_CLIENT_KEY=/etc/ssl/private/redis-client.key

# =============================================================================
# CLICKHOUSE TLS CONFIGURATION
# =============================================================================

# Enable TLS for ClickHouse connections
CLICKHOUSE_TLS_ENABLED=false

# ClickHouse TLS certificate paths
CLICKHOUSE_CA_CERT=/etc/ssl/certs/clickhouse-ca.crt
CLICKHOUSE_CLIENT_CERT=/etc/ssl/certs/clickhouse-client.crt
CLICKHOUSE_CLIENT_KEY=/etc/ssl/private/clickhouse-client.key

# =============================================================================
# DATA RETENTION POLICIES
# =============================================================================

# Conversation data retention (days)
CONVERSATION_RETENTION_DAYS=365

# Analytics data retention (days)
ANALYTICS_RETENTION_DAYS=730

# Audit log retention (days) - 7 years for compliance
AUDIT_LOG_RETENTION_DAYS=2555

# Session data retention (hours)
SESSION_RETENTION_HOURS=24

# =============================================================================
# CONSENT MANAGEMENT
# =============================================================================

# Default consent expiry (days)
DEFAULT_CONSENT_EXPIRY_DAYS=365

# Grace period after consent withdrawal (days)
CONSENT_WITHDRAWAL_GRACE_DAYS=30

# =============================================================================
# KEY ROTATION SETTINGS
# =============================================================================

# How often to check for keys needing rotation (minutes)
KEY_ROTATION_CHECK_INTERVAL_MINUTES=60

# Key rotation intervals by classification
CONFIDENTIAL_KEY_ROTATION_DAYS=90
RESTRICTED_KEY_ROTATION_DAYS=30

# =============================================================================
# SECURITY HEADERS
# =============================================================================

# Enable security headers
ENABLE_SECURITY_HEADERS=true

# HTTP Strict Transport Security
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000

# Content Security Policy
ENABLE_CSP=true
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# For development only - generates self-signed certificates
DEVELOPMENT_MODE=false
AUTO_GENERATE_CERTS=false

# Security logging level (DEBUG, INFO, WARNING, ERROR)
SECURITY_LOG_LEVEL=INFO

# Enable security audit logging to file
SECURITY_AUDIT_LOG_FILE=/var/log/unified-ai-system/security-audit.log

# =============================================================================
# COMPLIANCE SETTINGS
# =============================================================================

# Default compliance frameworks to enforce
DEFAULT_COMPLIANCE_FRAMEWORKS=gdpr,soc2

# Privacy request processing timeout (seconds)
PRIVACY_REQUEST_TIMEOUT=300

# Data export format for GDPR requests
DATA_EXPORT_FORMAT=json

# Anonymization settings
DEFAULT_ANONYMIZATION_LEVEL=standard
ENABLE_AUTOMATIC_ANONYMIZATION=true

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Encryption batch size for large datasets
ENCRYPTION_BATCH_SIZE=1000

# Audit log batch size for bulk operations
AUDIT_LOG_BATCH_SIZE=100

# Maximum concurrent encryption operations
MAX_CONCURRENT_ENCRYPTIONS=10

# Cache settings for decrypted data (seconds)
DECRYPTION_CACHE_TTL=300
DECRYPTION_CACHE_MAX_SIZE=1000

# =============================================================================
# MONITORING AND ALERTING
# =============================================================================

# Enable security metrics collection
ENABLE_SECURITY_METRICS=true

# Security alert endpoints (comma-separated)
SECURITY_ALERT_WEBHOOKS=""

# Compliance report schedule (cron format)
COMPLIANCE_REPORT_SCHEDULE="0 2 * * 0"  # Weekly on Sunday at 2 AM

# High-risk event notification settings
ENABLE_HIGH_RISK_NOTIFICATIONS=true
HIGH_RISK_NOTIFICATION_THRESHOLD=medium

# =============================================================================
# BACKUP AND RECOVERY
# =============================================================================

# Key backup settings
ENABLE_KEY_BACKUP=true
KEY_BACKUP_LOCATION=/var/backups/unified-ai-system/keys

# Configuration backup settings
ENABLE_CONFIG_BACKUP=true
CONFIG_BACKUP_LOCATION=/var/backups/unified-ai-system/config

# Backup encryption settings
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_RETENTION_DAYS=90